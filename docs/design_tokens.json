{
  "_meta": {
    "version": "1.0.0",
    "methodology": "Visual screenshot analysis + DOM computed style extraction",
    "sources": ["getlayers.ai", "godly.website", "refero.design", "landingfolio.com"],
    "date": "2026-07-15"
  },

  "color": {
    "backgrounds": {
      "base_dark_1": "#070708",
      "base_dark_2": "#0c0c0e",
      "base_dark_3": "#0a0a0c",
      "surface_elevated": "rgba(22, 22, 23, 1)",
      "surface_card": "rgba(255, 255, 255, 0.02)",
      "surface_card_hover": "rgba(255, 255, 255, 0.04)",
      "surface_nav": "rgba(255, 255, 255, 0.03)",
      "surface_nav_strong": "rgba(255, 255, 255, 0.08)"
    },
    "borders": {
      "default": "rgba(255, 255, 255, 0.05)",
      "medium": "rgba(255, 255, 255, 0.08)",
      "strong": "rgba(255, 255, 255, 0.12)",
      "bevel_top": "rgba(255, 255, 255, 0.35)",
      "bevel_side": "rgba(255, 255, 255, 0.15)",
      "bevel_bottom": "rgba(255, 255, 255, 0.30)"
    },
    "text": {
      "primary": "rgb(255, 255, 255)",
      "secondary": "rgba(255, 255, 255, 0.60)",
      "muted": "rgba(255, 255, 255, 0.35)",
      "disabled": "rgba(255, 255, 255, 0.20)"
    }
  },

  "typography": {
    "display_font": "Space Grotesk",
    "body_font": "Inter",
    "heading_letter_spacing": "-0.03em",
    "heading_line_height": "1.1",
    "body_line_height": "1.6",
    "sizes": {
      "h1_hero": "56px",
      "h1_section": "48px",
      "h2": "36px",
      "h3": "24px",
      "body_lg": "18px",
      "body_md": "16px",
      "body_sm": "14px",
      "label": "12px",
      "caption": "11px"
    },
    "weights": {
      "display": 700,
      "heading": 600,
      "body": 400,
      "label": 500
    }
  },

  "border_radius": {
    "none": "0px",
    "xs": "4px",
    "sm": "8px",
    "md": "12px",
    "lg": "16px",
    "xl": "20px",
    "2xl": "24px",
    "pill": "9999px"
  },

  "blur": {
    "subtle": "blur(4px)",
    "card": "blur(10px)",
    "nav": "blur(20px)",
    "modal": "blur(40px)",
    "nav_with_saturation": "saturate(150%) blur(12px)"
  },

  "spacing": {
    "scale": [4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96, 128],
    "component_gap": "8px",
    "section_padding": "80px 0",
    "card_padding": "20px 24px",
    "nav_padding": "8px 24px",
    "button_padding": "10px 20px"
  },

  "shadows": {
    "card_default": "0 1px 3px rgba(0, 0, 0, 0.3), 0 1px 2px rgba(0, 0, 0, 0.2)",
    "card_hover": "0 8px 32px rgba(0, 0, 0, 0.4), 0 2px 8px rgba(0, 0, 0, 0.2)",
    "glass_bevel": "0px -1px 0px rgba(255,255,255,0.35), 1px 0px 0px rgba(255,255,255,0.15), -1px 0px 0px rgba(255,255,255,0.15), 0px 1px 0px rgba(255,255,255,0.30), 0px 1px 1px rgba(0,0,0,0.20)",
    "glow_purple": "0 0 40px rgba(124, 92, 252, 0.25), 0 0 80px rgba(124, 92, 252, 0.10)",
    "glow_cyan": "0 0 40px rgba(61, 217, 255, 0.20), 0 0 80px rgba(61, 217, 255, 0.08)",
    "inset_top": "inset 0 1px 0 rgba(255, 255, 255, 0.08)"
  },

  "animation": {
    "durations": {
      "instant": "0.1s",
      "fast": "0.2s",
      "normal": "0.4s",
      "slow": "0.8s",
      "ambient": "4s"
    },
    "easings": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "expo_out": "cubic-bezier(0.16, 1, 0.3, 1)",
      "spring": "cubic-bezier(0.22, 1, 0.36, 1)",
      "linear": "linear"
    },
    "transitions": {
      "hover": "all 0.2s cubic-bezier(0.4, 0, 0.2, 1)",
      "reveal": "opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1), filter 0.8s",
      "color": "color 0.15s, background-color 0.15s, border-color 0.15s"
    }
  },

  "components": {
    "nav": {
      "type": "glass_pill",
      "border_radius": "9999px",
      "background": "rgba(255, 255, 255, 0.03)",
      "backdrop_filter": "blur(20px)",
      "border": "1px solid rgba(255, 255, 255, 0.08)",
      "padding": "8px 24px",
      "position": "fixed",
      "shadow": "0 1px 0 rgba(255, 255, 255, 0.05)"
    },
    "card": {
      "type": "glass_elevated",
      "border_radius": "16px",
      "background": "rgba(255, 255, 255, 0.02)",
      "backdrop_filter": "blur(10px)",
      "border": "1px solid rgba(255, 255, 255, 0.05)",
      "shadow_default": "0 1px 3px rgba(0, 0, 0, 0.3)",
      "shadow_hover": "0 8px 32px rgba(0, 0, 0, 0.4)",
      "inner_glow": "inset 0 1px 0 rgba(255, 255, 255, 0.08)",
      "transition": "all 0.2s cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "button_primary": {
      "type": "glass_pill",
      "border_radius": "9999px",
      "background": "rgba(90, 90, 90, 0.4)",
      "backdrop_filter": "saturate(150%) blur(12px)",
      "shadow": "0px -1px 0px rgba(255,255,255,0.35), 1px 0px 0px rgba(255,255,255,0.15), -1px 0px 0px rgba(255,255,255,0.15), 0px 1px 0px rgba(255,255,255,0.30), 0px 1px 1px rgba(0,0,0,0.20)",
      "padding": "10px 20px",
      "font_weight": 500
    },
    "input": {
      "border_radius": "12px",
      "background": "rgba(255, 255, 255, 0.04)",
      "border": "1px solid rgba(255, 255, 255, 0.08)",
      "focus_border": "1px solid rgba(255, 255, 255, 0.20)",
      "padding": "12px 16px",
      "font_size": "16px"
    },
    "badge_pill": {
      "border_radius": "9999px",
      "background": "rgba(255, 255, 255, 0.06)",
      "border": "1px solid rgba(255, 255, 255, 0.10)",
      "padding": "4px 12px",
      "font_size": "12px",
      "font_weight": 500,
      "letter_spacing": "0.04em"
    }
  },

  "component_decomposition": {
    "hero_section": {
      "children": ["AnnouncementPill","HeadingH1","SubtitleParagraph","CTAGroup","URLInputBar","SocialProofRow","StatsCounter","ProductVisual"],
      "bg_treatment": "ambient_blobs + grid_dots + noise_texture",
      "layout": "two_column_split"
    },
    "feature_card": {
      "children": ["Icon","Title","Description","StatBar","Visualization"],
      "hover_behavior": "tilt_3d + glow_border + glare_sweep",
      "glassmorphism": true
    },
    "navbar": {
      "children": ["Logo","NavLinks","ThemeSelector","CTAButton","UserAvatar"],
      "behavior": "transparent_on_top + frosted_on_scroll",
      "style": "floating_pill"
    }
  }
}
